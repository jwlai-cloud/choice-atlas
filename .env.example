# Add this in Vercel Project Settings > Environment Variables.
# Never commit a real key and never expose it through a VITE_ variable.
OPENAI_API_KEY=

# Required to unlock live GPT mapping. Store only the SHA-256 hash of a
# high-entropy code; give the original code directly to judges, never in a URL.
JUDGE_ACCESS_CODE_HASH=

# A separate random 32+ character secret used to sign the short-lived browser session.
JUDGE_SESSION_SECRET=
